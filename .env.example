# Stripe -- one or more restricted, read-only keys as a comma-separated
# "Label:key" list. Add a 4th+ account later by appending to this value, no
# code change needed. Example:
#   STRIPE_ACCOUNTS=Main Store:rk_live_aaa,Second Store:rk_live_bbb,Third Store:rk_live_ccc
STRIPE_ACCOUNTS=

# QuickBooks Online (Intuit Developer app)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
# Must exactly match the redirect URI registered on the Intuit app, e.g.
# https://<your-vercel-domain>/api/quickbooks/oauth-callback
QBO_REDIRECT_URI=

# ThriveCart (sales/order lookups -- see lib/thrivecart-sales-client.js for
# the open question on endpoint availability)
THRIVECART_API_KEY=
THRIVECART_API_BASE_URL=https://thrivecart.com

# Supabase (used only to persist QuickBooks OAuth tokens across invocations)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
