# App-level password gate for the dashboard's API routes (see
# lib/dashboard-auth.js). Needed because Vercel's own Deployment Protection
# on the Hobby plan doesn't cover production custom domains -- only a paid
# Pro plan's "All Deployments" protection does. Pick something you wouldn't
# mind being in a browser cookie; this isn't meant to withstand a serious
# attacker, just keep the dashboard off the open internet for a 2-person team.
DASHBOARD_PASSWORD=

# Stripe -- one or more restricted, read-only keys as a comma-separated
# "Label:key" list. Add a 4th+ account later by appending to this value, no
# code change needed. Example:
#   STRIPE_ACCOUNTS=Main Store:rk_live_aaa,Second Store:rk_live_bbb,Third Store:rk_live_ccc
STRIPE_ACCOUNTS=

# PayPal (client-credentials app, Apps & Credentials in the PayPal Developer
# dashboard -- no interactive OAuth consent needed, unlike QuickBooks)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# Product/subscription name matched against Stripe products and PayPal
# transaction text for the MRR card. Only set this if the product's name
# isn't literally "EDGE" in one or both systems.
# EDGE_PRODUCT_NAME=EDGE

# Exact Stripe Product IDs (prod_...) to treat as EDGE for MRR, in addition
# to the name match above -- use this when the product's name in Stripe
# doesn't reliably contain "EDGE". Find the ID on the product's page in the
# Stripe Dashboard (Product catalog -> click the product -> ID is in the URL
# and shown on the page). Comma-separated if EDGE has multiple products
# (e.g. one per Stripe account).
# STRIPE_EDGE_PRODUCT_IDS=prod_ABC123,prod_XYZ789

# QuickBooks Online (Intuit Developer app)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox
# Must exactly match the redirect URI registered on the Intuit app, e.g.
# https://<your-vercel-domain>/api/quickbooks/oauth-callback
QBO_REDIRECT_URI=

# Supabase (persists QuickBooks OAuth tokens across invocations)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
